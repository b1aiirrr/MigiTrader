<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="32" height="32">
  <rect width="32" height="32" rx="8" fill="#050810" stroke="rgba(255, 255, 255, 0.08)" stroke-width="1"/>
  <!-- Sleek, abstract, geometric market velocity upward trending arrow seamlessly combined with letter M -->
  <g transform="translate(1, 1)">
    <!-- Cyan neon glowing arrow outline -->
    <path d="M5 23 L11 15 L16 20 L25 8 M25 8 L18 8 M25 8 L25 15" 
          stroke="#00d4ff" 
          stroke-width="2.5" 
          stroke-linecap="round" 
          stroke-linejoin="round" 
          fill="none" />
    <!-- Royal blue interior depth line -->
    <path d="M5 23 L11 15 L16 20 L25 8" 
          stroke="#2563eb" 
          stroke-width="1.2" 
          stroke-linecap="round" 
          stroke-linejoin="round" 
          fill="none" />
    <!-- Micro-dot representing high-precision target execution -->
    <circle cx="25" cy="8" r="1.5" fill="#ffffff" />
  </g>
</svg>
