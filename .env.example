# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# NSE API Configuration
NEXT_PUBLIC_NSE_API_URL=https://api.nse.co.ke/v1
NEXT_PUBLIC_NSE_API_KEY=your_nse_api_key_here

# Redis Configuration (Upstash recommended for serverless)
REDIS_URL=redis://default:password@host:port
REDIS_PASSWORD=your_redis_password_here

# Ziidi Integration (Optional)
ZIIDI_PHONE_NUMBER=254700000000

# Application Settings
NEXT_PUBLIC_APP_NAME=MigiTrader
NEXT_PUBLIC_APP_VERSION=1.0.0
NODE_ENV=development

# Telegram Bot Alerts Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Signal Pipeline Configuration
# Comma-separated NSE tickers to monitor (omit to use full default watchlist)
EQUITY_WATCHLIST=SCOM,EQTY,KCB,DTK
# Minimum momentum score (0-100) to trigger a Telegram alert
SIGNAL_SCORE_THRESHOLD=40
